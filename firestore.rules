rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'email', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.email is string &&
             request.resource.data.createdAt is string;
    }

    function isValidProject() {
      return hasRequiredFields(['id', 'userId', 'name', 'prompt', 'status', 'createdAt', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidStringLength('name', 1, 100) &&
             request.resource.data.prompt is string &&
             request.resource.data.prompt.size() <= 10000 &&
             request.resource.data.status in ['draft', 'active'] &&
             request.resource.data.createdAt is string &&
             request.resource.data.updatedAt is string;
    }

    function isValidScreen() {
      return hasRequiredFields(['id', 'projectId', 'userId', 'name', 'code', 'prompt', 'x', 'y', 'createdAt', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidStringLength('name', 1, 100) &&
             request.resource.data.code is string &&
             request.resource.data.code.size() <= 1000000 && // 1MB limit
             request.resource.data.prompt is string &&
             request.resource.data.prompt.size() <= 10000 &&
             request.resource.data.x is number &&
             request.resource.data.y is number &&
             request.resource.data.createdAt is string &&
             request.resource.data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser() && request.resource.data.uid == resource.data.uid;
    }

    match /projects/{projectId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidProject();
      allow update: if isOwner(resource.data.userId) && isValidProject() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    match /screens/{screenId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidScreen();
      allow update: if isOwner(resource.data.userId) && isValidScreen() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);

      match /messages/{messageId} {
        allow read: if isOwner(get(/databases/$(database)/documents/screens/$(screenId)).data.userId);
        allow create: if isOwner(get(/databases/$(database)/documents/screens/$(screenId)).data.userId) &&
                      hasRequiredFields(['role', 'content', 'timestamp']) &&
                      request.resource.data.role in ['user', 'model'] &&
                      request.resource.data.content is string &&
                      request.resource.data.content.size() <= 100000;
        allow update: if isOwner(get(/databases/$(database)/documents/screens/$(screenId)).data.userId) &&
                      hasRequiredFields(['role', 'content', 'timestamp']) &&
                      request.resource.data.role in ['user', 'model'] &&
                      request.resource.data.content is string &&
                      request.resource.data.content.size() <= 100000;
        allow delete: if isOwner(get(/databases/$(database)/documents/screens/$(screenId)).data.userId);
      }
    }
  }
}
